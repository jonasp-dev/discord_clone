meta {
  name: Get Current User
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/v1/users/me
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

vars:pre-request {
  baseUrl: http://localhost:3000
  accessToken: eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiJjbW02bXBkamkwMDAwc2gzc3RnbXl4c2k4IiwiZW1haWwiOiJqb25hc0BnbWFpbC5jb20iLCJpYXQiOjE3NzIzMDE3NTQsImV4cCI6MTc3MjMwMjY1NH0.Ck2WWgBm2_mzEWJBewXStkHrLjlQmN6VoSFsjn-s_uo
