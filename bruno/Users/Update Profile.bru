meta {
  name: Update Profile
  type: http
  seq: 3
}

patch {
  url: {{baseUrl}}/api/v1/users/me
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "username": "updateduser",
    "status": "online"
  }
}

tests {
  test("Status code is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
}
